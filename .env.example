# Local StormReady runtime settings.
# Copy to .env and fill credentials locally. Do not commit .env.

# Source mode:
# - live: Open-Meteo, NWS alerts, and live local-context adapters
# - hybrid: live adapters plus mock local-context adapters
# - detailed_mock: detailed offline demo data
# - mock: simple offline weather
STORMREADY_V3_SOURCE_MODE=live

# AI provider:
# - auto: prefer Azure when Azure credentials are present, otherwise OpenAI
# - azure: require Azure OpenAI settings
# - openai: require OpenAI-compatible settings
STORMREADY_V3_AGENT_MODEL_PROVIDER=auto
STORMREADY_V3_AGENT_REASONING_EFFORT=medium

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT=

# OpenAI or OpenAI-compatible endpoint
STORMREADY_V3_OPENAI_API_KEY=
STORMREADY_V3_OPENAI_MODEL=gpt-4o-mini
STORMREADY_V3_OPENAI_BASE_URL=

# Optional local runtime overrides
# STORMREADY_V3_DB_PATH=runtime_data/local/stormready_v3.duckdb
# STORMREADY_V3_BACKGROUND_SUPERVISOR=0
# STORMREADY_V3_BACKGROUND_SUPERVISOR_INTERVAL_SECONDS=300
